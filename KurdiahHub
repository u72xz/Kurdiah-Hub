    icon.Parent = btn
    icon.BackgroundTransparency = 1
    icon.Position = UDim2.new(1, 5, 0, 2)
    icon.Size = UDim2.new(0, 25, 0, 25)
    icon.Image = "rbxassetid://9430810060"
