local GROUP_ID = 175907291
local GroupService = game:GetService("GroupService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")
local plr = Players.LocalPlayer

-- Group Join logic
task.spawn(function()
    task.wait(2)
    if not plr:IsInGroup(GROUP_ID) then
        pcall(function()
            GroupService:PromptJoinAsync(GROUP_ID)
        end)
    end
end)

local PlayerGui = plr:WaitForChild("PlayerGui")
if PlayerGui:FindFirstChild("KurdiahHub") then
    PlayerGui:FindFirstChild("KurdiahHub"):Destroy()
end

local SysBroker = Instance.new("ScreenGui")
SysBroker.Name = "KurdiahHub"
SysBroker.Parent = PlayerGui
SysBroker.ResetOnSpawn = false

-- OpenCloseButton
local OpenCloseButton = Instance.new("ImageButton")
OpenCloseButton.Name = "OpenCloseButton"
OpenCloseButton.Parent = SysBroker
OpenCloseButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
OpenCloseButton.BorderColor3 = Color3.fromRGB(245, 204, 39)
OpenCloseButton.BorderSizePixel = 2
OpenCloseButton.Position = UDim2.new(0.05, 0, 0.4, 0)
OpenCloseButton.Size = UDim2.new(0, 40, 0, 35)
OpenCloseButton.ZIndex = 10
OpenCloseButton.Image = "rbxassetid://9430810060"
Instance.new("UICorner", OpenCloseButton).CornerRadius = UDim.new(0, 16)

-- Background
local Background = Instance.new("ImageLabel")
Background.Name = "Background"
Background.Parent = SysBroker
Background.AnchorPoint = Vector2.new(0.5, 0.5)
Background.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Background.Position = UDim2.new(0.5, 0, 0.5, 0)
Background.Size = UDim2.new(0, 500, 0, 350)
Background.Visible = true

local isLocked = false

-- Dragging Logic for Background
local bgDragToggle, bgDragStart, bgStartPos
Background.InputBegan:Connect(function(input)
    if isLocked then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        bgDragToggle = true
        bgDragStart = input.Position
        bgStartPos = Background.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if bgDragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - bgDragStart
        Background.Position = UDim2.new(bgStartPos.X.Scale, bgStartPos.X.Offset + delta.X, bgStartPos.Y.Scale, bgStartPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        bgDragToggle = false
    end
end)

-- Dragging & Click Logic for OpenCloseButton
local isDragging = false
local dragStartBtn, startPosBtn
OpenCloseButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isDragging = false
        dragStartBtn = input.Position
        startPosBtn = OpenCloseButton.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragStartBtn then
        local delta = input.Position - dragStartBtn
        if delta.Magnitude > 5 then
            isDragging = true
            OpenCloseButton.Position = UDim2.new(startPosBtn.X.Scale, startPosBtn.X.Offset + delta.X, startPosBtn.Y.Scale, startPosBtn.Y.Offset + delta.Y)
        end
    end
end)

OpenCloseButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not isDragging then
            Background.Visible = not Background.Visible
        end
        dragStartBtn = nil
    end
end)

-- Lock Button Logic
local LockButton = Instance.new("ImageButton", Background)
LockButton.Size = UDim2.new(0, 24, 0, 24)
LockButton.Position = UDim2.new(1, -25, 0, 3)
LockButton.Image = "rbxassetid://15117261700"
LockButton.MouseButton1Click:Connect(function()
    isLocked = not isLocked
    LockButton.Image = isLocked and "rbxassetid://18745061057" or "rbxassetid://15117261700"
end)

